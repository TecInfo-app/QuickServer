rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net: Default-deny catch-all rule
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE SECURITY HELPERS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isCentralAdmin() {
      return isSignedIn() && request.auth.token.email.lower() == 'iranildo@quickserve.com';
    }

    function hasStoreAccess(storeId) {
      return isSignedIn() && (
        isCentralAdmin() ||
        request.auth.token.email.lower().matches('.*_' + storeId.lower() + '@quickserve.com$') ||
        (exists(/databases/$(database)/documents/stores/$(storeId)) && 
         get(/databases/$(database)/documents/stores/$(storeId)).data.email.lower() == request.auth.token.email.lower())
      );
    }

    // --- PATH MATCHERS ---

    // Stores collection
    match /stores/{storeId} {
      // Anyone signed in can read stores (necessary for initial sync)
      allow read: if isSignedIn();
      
      // Central admin or the store owner can create/update store documents
      allow create: if isCentralAdmin() || (isSignedIn() && request.resource.data.email.lower() == request.auth.token.email.lower());
      allow update: if isCentralAdmin() || hasStoreAccess(storeId);
      allow delete: if isCentralAdmin();

      // Users sub-collection
      match /users/{userId} {
        allow read, write: if hasStoreAccess(storeId);
      }

      // Inventory sub-collection
      match /inventory/{productId} {
        allow read, write: if hasStoreAccess(storeId);
      }

      // Tables sub-collection
      match /tables/{tableId} {
        allow read, write: if hasStoreAccess(storeId);
      }

      // Transactions sub-collection
      match /transactions/{transactionId} {
        allow read, write: if hasStoreAccess(storeId);
      }
    }
  }
}
